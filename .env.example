ADMIN_ACCESS_KEY=choose-a-long-random-admin-key
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Optional admin bootstrap (if you add admin role seeding logic)
ADMIN_EMAIL=
